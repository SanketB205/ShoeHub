# Copy this file to .env and fill in your values

PORT=5000

# ── Local MySQL ──────────────────────────────────────────────────
DB_NAME=shoehub_db
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql

# ── Railway MySQL (set these in Railway dashboard environment vars) ──
# The MYSQL* variables are auto-injected by Railway when you attach a MySQL plugin.
# database.js reads them automatically — no code change needed.
#
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=your_railway_password
# MYSQLHOST=mysql.railway.internal
# MYSQLPORT=3306

# CORS – comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
